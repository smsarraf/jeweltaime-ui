# Airwallex API Credentials
# Get these from your Airwallex account: Settings > API Keys
AIRWALLEX_API_KEY=your_api_key_here
AIRWALLEX_CLIENT_ID=your_client_id_here
AIRWALLEX_WEBHOOK_SECRET=your_webhook_secret_here

# Airwallex Environment
# Set to 'demo' for testing, 'prod' for live
AIRWALLEX_ENV=demo

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:5173