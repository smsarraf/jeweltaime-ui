# Airwallex API Credentials
# Get these from your Airwallex account: Settings > API Keys
AIRWALLEX_API_KEY=your_api_key_here
AIRWALLEX_CLIENT_ID=your_client_id_here
AIRWALLEX_WEBHOOK_SECRET=your_webhook_secret_here

# Airwallex Environment
# Set to 'demo' for testing, 'prod' for live
AIRWALLEX_ENV=demo

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:5173

# JWT Secrets (change these in production!)
JWT_SECRET=jeweltaime-super-secret-key-change-in-production
JWT_REFRESH_SECRET=jeweltaime-refresh-secret-change-in-production
SESSION_SECRET=jeweltaime-session-secret

# Social Login - Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/social/google/callback

# Social Login - Facebook OAuth
# Get credentials from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/social/facebook/callback

# Social Login - Instagram OAuth
# Get credentials from: https://developers.facebook.com/docs/instagram-basic-display-api/
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_CALLBACK_URL=http://localhost:3001/api/auth/social/instagram/callback
